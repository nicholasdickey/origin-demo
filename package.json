{
  "name": "origin-demo",
  "version": "0.1.0",
  "description": "Origin By Genisent — MCP App demo (mock FamilySearch + archive email)",
  "type": "module",
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "build": "tsx ./build-all.mts",
    "vercel-build": "pnpm build",
    "serve": "serve -s ./assets -p 4444 --cors",
    "serve:mcp-app": "tsx server.ts",
    "dev": "vite --config vite.config.mts",
    "tsc": "tsc -b",
    "tsc:app": "tsc -p tsconfig.app.json",
    "tsc:node": "tsc -p tsconfig.node.json"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.1",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.2.2",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
